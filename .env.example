# Browser-safe variables. These three values also belong in Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=

# Server-only variables. Never expose these with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_SITE_URL=

# Instagram / Meta
INSTAGRAM_USER_ID=
INSTAGRAM_USERNAME=elfactonoticias
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
# Use the Graph API version approved for the Meta app, for example vXX.X.
INSTAGRAM_GRAPH_VERSION=
INSTAGRAM_SYNC_CRON_SECRET=
INSTAGRAM_WORKER_SECRET=

# OpenAI API
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Choose an available Responses API model in the OpenAI project.
OPENAI_EDITORIAL_MODEL=
MAX_TRANSCRIPTION_BYTES=24000000

# Optional compatibility adapter. Native publishing uses Supabase directly.
CMS_PUBLISH_ENDPOINT=
CMS_PUBLISH_SECRET=
